RewriteEngine On

# Security Headers
<IfModule mod_headers.c>
    # Content Security Policy - Allow embedding GitHub Sponsors card iframe
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://cdn.jsdelivr.net; connect-src 'self'; frame-src 'self' https://docs.google.com https://github.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    
    # Additional security headers
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options "ALLOW-FROM https://github.com"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# If the request is for a file or directory that exists, serve it as is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If the request does not contain a file extension, try appending .php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,4}$
RewriteRule ^(.*)$ $1.php [L]
# If the request is for rss.xml, serve it as rss.xml.php
RewriteRule ^rss\.xml$ rss.xml.php [L]
